# Run `namecheap-mcp-setup` for interactive setup (recommended).
# Or configure interactively in Claude Code by calling the `setup` MCP tool.
# This file is for local project-level overrides only.
# User-global config lives at ~/.config/namecheap-mcp/.env

# Required
NAMECHEAP_API_USER=yourUsername
NAMECHEAP_API_KEY=yourApiKeyHere
NAMECHEAP_CLIENT_IP=1.2.3.4

# Optional — only needed if API username differs from account username (rare)
# NAMECHEAP_USERNAME=yourUsername

# Optional — set to "true" to use the sandbox API (api.sandbox.namecheap.com)
NAMECHEAP_SANDBOX=false
