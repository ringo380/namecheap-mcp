{
  "name": "namecheap-mcp",
  "version": "1.0.0",
  "description": "MCP server for the Namecheap API — domains, DNS, SSL, and account management",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "namecheap-mcp": "dist/index.js",
    "namecheap-mcp-setup": "dist/setup.js"
  },
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js dist/setup.js",
    "prepare": "npm run build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.3",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "fast-xml-parser": "^5.5.7",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
