{
  "name": "namecheap-mcp",
  "version": "1.5.0",
  "description": "MCP server for the Namecheap API — domains, DNS, SSL, and account management",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "namecheap-mcp": "dist/index.js",
    "namecheap-mcp-setup": "dist/setup.js"
  },
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js dist/setup.js",
    "prepare": "npm run build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.3",
    "axios": "^1.7.0",
    "dotenv": "^17.4.2",
    "fast-xml-parser": "^5.7.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.4"
  }
}
